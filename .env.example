# Forgejo instance hostname (used by Traefik and Forgejo config)
FORGEJO_HOST=forgejo.wandergeek.org

# Image to use — pin to a specific digest for reproducibility
# Example: codeberg.org/forgejo/forgejo:10@sha256:<digest>
FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:14

# Container / volume naming (optional overrides)
FORGEJO_CONTAINER_NAME=forgejo
FORGEJO_VOLUME_NAME=forgejo_data

# UID/GID for the forgejo process inside the container
USER_UID=1000
USER_GID=1000

# SSH — the host port that maps to Forgejo's SSH server (22 is typically taken by the host)
SSH_EXPOSE_PORT=2222

# Database backend: sqlite3 (default) | postgres | mysql
DB_TYPE=sqlite3

# Security — generate with: openssl rand -hex 32
SECRET_KEY=changeme
INTERNAL_TOKEN=changeme

# Registration & access control
DISABLE_REGISTRATION=true
REQUIRE_SIGNIN_VIEW=true

# Traefik integration
TRAEFIK_NETWORK_NAME=traefik_default
TRAEFIK_CERTRESOLVER=myresolver

# Mailer (optional)
MAILER_ENABLED=false
